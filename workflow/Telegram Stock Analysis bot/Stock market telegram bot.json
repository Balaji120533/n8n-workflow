    {
      "parameters": {
        "jsCode": "\nreturn $input.all().map(item => {\n  \n  // Grab the data for the current stock in the loop\n  const data = item.json.chart.result[0].meta;\n  \n  // Package it up and send it to the next node\n  return {\n    json: {\n      symbol: data.symbol,\n      current_price: data.regularMarketPrice,\n      previous_close: data.chartPreviousClose,\n      day_high: data.regularMarketDayHigh,\n      day_low: data.regularMarketDayLow,\n      volume: data.regularMarketVolume\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
