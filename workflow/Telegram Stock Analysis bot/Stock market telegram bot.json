    {
      "parameters": {
        "jsCode": "const messageText = $input.first().json.message.text;\nconst parts = messageText.split(' ');\nconst condition = parts[0];\n\n// Grab everything AFTER the /analyze command and join it back together\nlet rawSymbol = parts.slice(1).join(' ').trim();\n\n// Safety check: if they didn't type a stock at all\nif (!rawSymbol) {\n  return { con: condition, ticker: \"\" };\n}\n\n// Remove accidental spaces (e.g., turning \"INDIAN OIL\" into \"INDIANOIL\")\n// because Yahoo Finance tickers do not have spaces.\nlet symbol = rawSymbol.replace(/\\s+/g, '');\n\nlet ticker = symbol;\nlet ex = \"NS\"; // Default to NSE if they forget the dot\n\n// Safe check for the dot\nif (symbol.includes('.')) {\n  splitSymbol = symbol.split('.');\n  ticker = splitSymbol[0];\n  let exRaw = splitSymbol[1].toUpperCase();\n  \n  if (exRaw === \"BSE\" || exRaw === \"bse\") ex = \"BO\";\n  else if (exRaw === \"NSE\" || exRaw === \"nse\") ex = \"NS\";\n  else ex = exRaw;\n}\n\nreturn {\n  ticker: ticker.toUpperCase() + \".\" + ex,\n  con: condition,\n  chat_id: $input.first().json.message.chat.id\n};"
      },
